# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_password
DATABASE_NAME=back_it_onchain

# Oracle Configuration - EVM (Base)
ORACLE_PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234
OUTCOME_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# Oracle Configuration - Stellar
# Generate with: node -e "const { Keypair } = require('@stellar/stellar-sdk'); const kp = Keypair.random(); console.log('Secret:', kp.secret());"
STELLAR_ORACLE_SECRET_KEY=SCXJ4DAPQMXLKP3QITADMVLNX5Q7PV4L3BQKVME4N6TL5M2VJJYR7FAS

# Authentication
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-strong-random-secret

# IPFS Configuration
# Option A: Local Kubo node (default)
IPFS_API_URL=http://localhost:5001
# Option B: Pinata cloud (set your JWT from https://app.pinata.cloud)
# PINATA_JWT=eyJhbGc...

# Application Configuration
PORT=3000
NODE_ENV=development
