# ── Environment ───────────────────────────────────────────────────────────
# Options: development | production | test
NODE_ENV=development

# Application port (default: 3001)
PORT=3001

# ── Database (PostgreSQL) ──────────────────────────────────────────────────
# Required in production. Defaults provided for local development.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=back_it_onchain

# ── Authentication (JWT) ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Required in production (min 32 chars). Defaults to "dev-secret" in development.
JWT_SECRET=dev-secret

# ── Oracle — EVM (Base) ───────────────────────────────────────────────────
# 64-char hex private key prefixed with 0x.
# Required in production. Optional in development (oracle endpoints will fail if missing).
ORACLE_PRIVATE_KEY=0x1234567890123456789012345678901234567890123456789012345678901234

# EVM contract address for the OutcomeManager (0x + 40 hex chars).
# Required if the oracle needs to sign EIP-712 outcomes.
OUTCOME_MANAGER_ADDRESS=0x1234567890123456789012345678901234567890

# ── Oracle — Stellar ──────────────────────────────────────────────────────
# Generate with: node -e "const { Keypair } = require('@stellar/stellar-sdk'); const kp = Keypair.random(); console.log('Secret:', kp.secret());"
# Must start with 'S' followed by 55 alphanumeric chars.
STELLAR_ORACLE_SECRET_KEY=SCXJ4DAPQMXLKP3QITADMVLNX5Q7PV4L3BQKVME4N6TL5M2VJJYR7FAS

# ── Indexer (Base Sepolia) ────────────────────────────────────────────────
# HTTP/HTTPS URL for the Base Sepolia RPC endpoint.
# If not set, the on-chain indexer will be disabled.
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# EVM contract address for the CallRegistry (0x + 40 hex chars).
# If not set, the on-chain indexer will be disabled.
CALL_REGISTRY_ADDRESS=0x1234567890123456789012345678901234567890

# ── IPFS ──────────────────────────────────────────────────────────────────
# Option A: Local Kubo node (default)
IPFS_API_URL=http://localhost:5001
# Option B: Pinata cloud (set your JWT from https://app.pinata.cloud)
# PINATA_JWT=eyJhbGc...

# ── Admin ────────────────────────────────────────────────────────────────
# API key required in the x-admin-api-key header for admin routes.
# If not set, all admin requests are rejected (fail-safe).
ADMIN_API_KEY=

# ── Redis (optional) ─────────────────────────────────────────────────────
# If not set, falls back to in-memory cache.
# REDIS_URL=redis://localhost:6379

# ── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the main HTTP server.
# CORS_ORIGINS=http://localhost:3000,https://app.example.com
# Single origin for WebSocket gateway CORS.
# CORS_ORIGIN=http://localhost:3000

# ── Notifications ─────────────────────────────────────────────────────────
# Number of days to retain notifications before auto-cleanup (default: 30).
NOTIFICATION_RETENTION_DAYS=30

# ── Discord (optional — admin alerts) ─────────────────────────────────────
# HTTPS webhook URL for abandoned-call admin alerts.
# DISCORD_ADMIN_WEBHOOK_URL=https://discord.com/api/webhooks/...
